import { createClient } from "npm:@supabase/supabase-js";
// import Stripe from "npm:stripe";

const SUPABASE_URL = Deno.env.get("SUPABASE_URL") ?? "";
const SUPABASE_SERVICE_ROLE_KEY = Deno.env.get("SUPABASE_SERVICE_ROLE_KEY") ?? "";
// const STRIPE_SECRET_KEY = Deno.env.get("STRIPE_SECRET_KEY") ?? "";
// const STRIPE_API_VERSION = Deno.env.get("STRIPE_API_VERSION") ?? "2024-04-10";
// const STRIPE_WEBHOOK_SECRET = Deno.env.get("STRIPE_WEBHOOK_SECRET") ?? "";
// const STRIPE_CHECKOUT_SUCCESS_URL = Deno.env.get("STRIPE_CHECKOUT_SUCCESS_URL") ?? "";
// const STRIPE_CHECKOUT_CANCEL_URL = Deno.env.get("STRIPE_CHECKOUT_CANCEL_URL") ?? "";
// const PREMIUM_PRICE_ID = Deno.env.get("VITE_STRIPE_PREMIUM_PRICE_ID") ?? "";
// const FAMILY_PRICE_ID = Deno.env.get("VITE_STRIPE_FAMILY_PRICE_ID") ?? "";
const ADMIN_API_KEY = Deno.env.get("ADMIN_API_KEY") ?? "";
const VAPID_PUBLIC_KEY = Deno.env.get("VAPID_PUBLIC_KEY") ?? "";
const RESEND_API_KEY = Deno.env.get("RESEND_API_KEY") ?? "";

const supabase = createClient(SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, {
  auth: { persistSession: false },
});
// const stripe = new Stripe(STRIPE_SECRET_KEY, {
//   apiVersion: STRIPE_API_VERSION,
// }) as any;

function jsonResponse(body: unknown, init: ResponseInit = {}) {
  return new Response(JSON.stringify(body), {
    headers: {
      "Content-Type": "application/json",
      "Access-Control-Allow-Origin": "*",
      "Access-Control-Allow-Methods": "GET,POST,PUT,PATCH,DELETE,OPTIONS",
      "Access-Control-Allow-Headers": "Authorization,Content-Type",
      ...init.headers,
    },
    ...init,
  });
}

function parseJwtPayload(token: string) {
  try {
    const parts = token.split('.');
    if (parts.length < 2) return null;
    let payload = parts[1];
    payload = payload.replace(/-/g, '+').replace(/_/g, '/');
    while (payload.length % 4 !== 0) payload += '=';
    const decoded = atob(payload);
    return JSON.parse(decoded);
  } catch {
    return null;
  }
}

async function getUserIdFromRequest(req: Request): Promise<string | null> {
  const authHeader = req.headers.get('Authorization');
  if (!authHeader?.startsWith('Bearer ')) return null;
  const token = authHeader.slice(7);
  const payload = parseJwtPayload(token);
  return payload?.sub ?? null;
}

async function handleGetMetrics(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: subs } = await supabase
    .from('subscriptions')
    .select('*')
    .eq('user_id', userId);

  if (!subs) return jsonResponse({ error: 'Failed to fetch subscriptions' }, { status: 500 });

  const activeSubs = (subs as any[]).filter(s => s.status === 'active');
  const totalCost = activeSubs.reduce((sum, s) => sum + (s.cost_per_month || 0), 0);
  const totalItems = activeSubs.length;

  return jsonResponse({
    totalCost,
    totalItems,
    activeSubs: totalItems,
    inactiveSubs: ((subs as any[]).length - totalItems),
    metrics: {
      healthScore: Math.min(100, Math.max(0, 100 - (totalItems * 5))),
    },
  });
}

async function handleCreateCheckoutSession(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  try {
    const body = await req.json() as any;
    const priceId = body.priceId || PREMIUM_PRICE_ID;

    const { data: user } = await supabase.auth.admin.getUserById(userId);
    if (!user) return jsonResponse({ error: 'User not found' }, { status: 404 });

    const session = await stripe.checkout.sessions.create({
      customer_email: user.email,
      client_reference_id: userId,
      line_items: [{ price: priceId, quantity: 1 }],
      mode: 'subscription',
      success_url: STRIPE_CHECKOUT_SUCCESS_URL,
      cancel_url: STRIPE_CHECKOUT_CANCEL_URL,
      metadata: { user_id: userId },
      subscription_data: { metadata: { user_id: userId } },
    });

    return jsonResponse({ sessionId: session.id });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

function getPriceIdFromSubscription(subscription: any): string | undefined {
  if (!subscription?.items?.data?.length) {
    return undefined;
  }

  const items = subscription.items.data as any[];
  const recurringItems = items.filter(
    (item: any) =>
      item?.price?.type === 'recurring' &&
      item?.quantity > 0 &&
      item?.deleted !== true
  );

  const item =
    recurringItems[0] ||
    items.find((item: any) => item?.price?.type === 'recurring') ||
    items[0];

  return item?.price?.id;
}

function getPlanTypeFromSubscription(subscription: any): 'free' | 'premium' | 'family' {
  try {
    const priceId = getPriceIdFromSubscription(subscription);
    if (priceId === PREMIUM_PRICE_ID) return 'premium';
    if (priceId === FAMILY_PRICE_ID) return 'family';

    const item = subscription.items?.data?.[0];
    const price = item?.price;
    if (price?.metadata?.plan_type) {
      return price.metadata.plan_type as 'free' | 'premium' | 'family';
    }
  } catch {
    // ignore
  }

  return 'premium';
}

async function handleStripeCheckoutCompleted(session: any): Promise<void> {
  const customerId = typeof session.customer === 'string' ? session.customer : session.customer?.id;
  let userId = session.metadata?.user_id as string | undefined;
  const subscriptionId = typeof session.subscription === 'string' ? session.subscription : session.subscription?.id;

  if (!subscriptionId) {
    throw new Error('Checkout session did not complete a subscription');
  }

  if (!userId && customerId) {
    const { data: existing } = await supabase
      .from('user_subscriptions')
      .select('user_id')
      .eq('stripe_customer_id', customerId)
      .single();

    if (existing?.user_id) {
      userId = existing.user_id;
    }
  }

  if (!userId && customerId) {
    try {
      const customer = await stripe.customers.retrieve(customerId) as any;
      userId = customer?.metadata?.user_id;
    } catch {
      // ignore
    }
  }

  if (!userId) {
    throw new Error('Unable to resolve user_id for checkout session');
  }

  const subscription = await stripe.subscriptions.retrieve(subscriptionId, {
    expand: ['items.data.price'],
  }) as any;

  const priceId = getPriceIdFromSubscription(subscription);
  const planType = priceId
    ? priceId === PREMIUM_PRICE_ID
      ? 'premium'
      : priceId === FAMILY_PRICE_ID
      ? 'family'
      : getPlanTypeFromSubscription(subscription)
    : getPlanTypeFromSubscription(subscription);

  const payload: any = {
    user_id: userId,
    stripe_customer_id: customerId,
    stripe_subscription_id: subscriptionId,
    stripe_price_id: priceId ?? null,
    status: subscription.status,
    plan_type: planType,
    current_period_start: subscription.current_period_start ? new Date(subscription.current_period_start * 1000).toISOString() : null,
    current_period_end: subscription.current_period_end ? new Date(subscription.current_period_end * 1000).toISOString() : null,
    cancel_at_period_end: !!subscription.cancel_at_period_end,
    updated_at: new Date().toISOString(),
  };

  const { error } = await supabase
    .from('user_subscriptions')
    .upsert(payload, { onConflict: 'user_id' });

  if (error) {
    console.error('[Stripe] Failed to upsert checkout session subscription row:', error);
  }
}

async function handleCompleteCheckoutSession(req: Request): Promise<Response> {
  try {
    const body = await req.json() as any;
    const sessionId = body.sessionId;
    if (!sessionId) {
      return jsonResponse({ error: 'sessionId is required' }, { status: 400 });
    }

    const session = await stripe.checkout.sessions.retrieve(sessionId, {
      expand: ['subscription', 'customer'],
    }) as any;

    await handleStripeCheckoutCompleted(session);
    return jsonResponse({ success: true });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleGetStripeSubscriptionStatus(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: subscription, error } = await supabase
    .from('user_subscriptions')
    .select('stripe_subscription_id, plan_type, status')
    .eq('user_id', userId)
    .single();

  if (error || !subscription) {
    return jsonResponse({ status: 'free', tier: 'free' });
  }

  return jsonResponse({
    status: subscription.stripe_subscription_id ? 'active' : 'inactive',
    tier: subscription.plan_type || 'free',
    subscriptionId: subscription.stripe_subscription_id,
  });
}

async function handleCancelSubscription(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: subscription, error } = await supabase
    .from('user_subscriptions')
    .select('stripe_subscription_id')
    .eq('user_id', userId)
    .single();

  if (error || !subscription?.stripe_subscription_id) {
    return jsonResponse({ success: true, message: 'No active subscription found; already on free plan.' });
  }

  try {
    await stripe.subscriptions.update(subscription.stripe_subscription_id, {
      cancel_at_period_end: true,
    });

    await supabase
      .from('user_subscriptions')
      .update({ cancel_at_period_end: true, updated_at: new Date().toISOString() })
      .eq('user_id', userId);

    return jsonResponse({ success: true, message: 'Subscription cancelled' });
  } catch (err: any) {
    const missing = err?.code === 'resource_missing' || err?.raw?.code === 'resource_missing';
    if (missing) {
      await supabase
        .from('user_subscriptions')
        .update({ status: 'canceled', plan_type: 'free', stripe_subscription_id: null, updated_at: new Date().toISOString() })
        .eq('user_id', userId);
      return jsonResponse({ success: true, message: 'Stale Stripe subscription cleaned up and downgraded to free.' });
    }
    return jsonResponse({ error: (err as Error).message }, { status: 500 });
  }
}

async function handleReactivateSubscription(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: subscription, error } = await supabase
    .from('user_subscriptions')
    .select('stripe_subscription_id')
    .eq('user_id', userId)
    .single();

  if (error || !subscription?.stripe_subscription_id) {
    return jsonResponse({ error: 'No subscription to reactivate' }, { status: 400 });
  }

  try {
    await stripe.subscriptions.update(subscription.stripe_subscription_id, {
      cancel_at_period_end: false,
    });

    await supabase
      .from('user_subscriptions')
      .update({ cancel_at_period_end: false, updated_at: new Date().toISOString() })
      .eq('user_id', userId);

    return jsonResponse({ success: true, message: 'Subscription reactivated' });
  } catch (err: any) {
    return jsonResponse({ error: (err as Error).message }, { status: 500 });
  }
}

async function handleGetPremiumStatus(req: Request): Promise<Response> {
  try {
    const userId = await getUserIdFromRequest(req);
    if (!userId) {
      return jsonResponse({
        isPremium: false,
        planType: 'free',
        status: 'inactive',
        cancelAtPeriodEnd: false,
        currentPeriodEnd: null,
        currency: 'USD',
      });
    }

    const { data: userSub, error } = await supabase
      .from('user_subscriptions')
      .select('plan_type, status, cancel_at_period_end, current_period_end')
      .eq('user_id', userId)
      .single();

    if (error || !userSub) {
      return jsonResponse({
        isPremium: false,
        planType: 'free',
        status: 'inactive',
        cancelAtPeriodEnd: false,
        currentPeriodEnd: null,
        currency: 'USD',
      });
    }

    let currency = 'USD';
    const authHeader = req.headers.get('Authorization')?.replace('Bearer ', '') || '';
    if (authHeader) {
      try {
        const { data } = await supabase.auth.getUser(authHeader);
        if (data.user?.user_metadata?.currency) {
          currency = data.user.user_metadata.currency as string;
        }
      } catch {
        // ignore auth metadata errors
      }
    }

    if (currency === 'USD') {
      const { data: userRecord } = await supabase
        .from('users')
        .select('currency')
        .eq('id', userId)
        .single();
      if (userRecord?.currency) {
        currency = userRecord.currency;
      }
    }

    return jsonResponse({
      isPremium: userSub.plan_type !== 'free' && userSub.status === 'active',
      planType: userSub.plan_type || 'free',
      status: userSub.status || 'inactive',
      cancelAtPeriodEnd: userSub.cancel_at_period_end || false,
      currentPeriodEnd: userSub.current_period_end,
      currency,
    });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handlePatchUserCurrency(req: Request): Promise<Response> {
  try {
    const userId = await getUserIdFromRequest(req);
    if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

    const body = await req.json() as any;
    const currency = String(body.currency || '').toUpperCase();
    if (!currency || !/^[A-Z]{3}$/.test(currency)) {
      return jsonResponse({ error: 'Invalid currency code' }, { status: 400 });
    }

    try {
      const { error } = await supabase.auth.admin.updateUserById(userId, {
        user_metadata: { currency },
      });
      if (error) {
        console.warn('[Routes] PATCH /api/user/currency auth update error', error.message);
      }
    } catch (err) {
      console.warn('[Routes] PATCH /api/user/currency auth exception', err);
    }

    try {
      await supabase.from('users').upsert({ id: userId, currency });
    } catch (err) {
      console.warn('[Routes] failed to upsert currency into users table', err);
    }

    return jsonResponse({ currency });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleGetNotificationPreferences(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data, error } = await supabase
    .from('notification_preferences')
    .select('email_notifications, push_notifications, weekly_digest')
    .eq('user_id', userId)
    .single();

  if (error || !data) {
    return jsonResponse({
      emailNotifications: true,
      pushNotifications: true,
      weeklyDigest: true,
    });
  }

  return jsonResponse({
    emailNotifications: data.email_notifications ?? true,
    pushNotifications: data.push_notifications ?? true,
    weeklyDigest: data.weekly_digest ?? true,
  });
}

async function handlePatchNotificationPreferences(req: Request): Promise<Response> {
  try {
    const userId = await getUserIdFromRequest(req);
    if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

    const body = await req.json() as any;
    const emailNotifications = Boolean(body.emailNotifications);
    const pushNotifications = Boolean(body.pushNotifications);
    const weeklyDigest = Boolean(body.weeklyDigest);

    const { error } = await supabase
      .from('notification_preferences')
      .upsert(
        {
          user_id: userId,
          email_notifications: emailNotifications,
          push_notifications: pushNotifications,
          weekly_digest: weeklyDigest,
          updated_at: new Date().toISOString(),
        },
        { onConflict: 'user_id' }
      );

    if (error) {
      return jsonResponse({ error: 'Failed to save preferences' }, { status: 500 });
    }

    return jsonResponse({
      emailNotifications,
      pushNotifications,
      weeklyDigest,
    });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleStripeWebhook(req: Request): Promise<Response> {
  try {
    const signature = req.headers.get('stripe-signature') || '';
    const bodyText = await req.text();

    if (!STRIPE_WEBHOOK_SECRET) {
      return jsonResponse({ error: 'Webhook not configured' }, { status: 400 });
    }

    const event = stripe.webhooks.constructEvent(bodyText, signature, STRIPE_WEBHOOK_SECRET);

    switch (event.type) {
      case 'checkout.session.completed':
        await handleStripeCheckoutCompleted(event.data.object);
        break;
      default:
        console.log('[Stripe] Unhandled webhook event type:', event.type);
    }

    return jsonResponse({ success: true });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleGetListSubscriptions(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const url = new URL(req.url);
  const page = Number(url.searchParams.get('page') || '1');
  const perPage = Number(url.searchParams.get('perPage') || '100');
  const normalizedPage = Number.isNaN(page) || page < 1 ? 1 : page;
  const normalizedPerPage = Number.isNaN(perPage) || perPage < 1 ? 100 : perPage > 1000 ? 1000 : perPage;
  const from = (normalizedPage - 1) * normalizedPerPage;
  const to = normalizedPage * normalizedPerPage - 1;

  const { data, error, count } = await supabase
    .from('subscriptions')
    .select('*', { count: 'exact' })
    .eq('user_id', userId)
    .order('created_at', { ascending: false })
    .range(from, to);

  if (error) return jsonResponse({ error: 'Failed to fetch subscriptions' }, { status: 500 });

  const response = jsonResponse(data || []);
  if (typeof count === 'number') {
    response.headers.set('x-total-count', String(count));
  }
  return response;
}

async function handleCreateSubscription(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  try {
    const body = await req.json() as any;
    const { name, cost_per_month = 0, renewal_date, category = 'other' } = body;

    if (!name) return jsonResponse({ error: 'Name is required' }, { status: 400 });

    const { data, error } = await supabase
      .from('subscriptions')
      .insert({
        user_id: userId,
        name,
        cost_per_month,
        renewal_date,
        category,
        status: 'active',
        created_at: new Date().toISOString(),
      })
      .select()
      .single();

    if (error) return jsonResponse({ error: 'Failed to create subscription' }, { status: 500 });
    return jsonResponse(data, { status: 201 });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleUpdateSubscription(req: Request, id: string): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  try {
    const body = await req.json() as any;

    const { data: existing } = await supabase
      .from('subscriptions')
      .select('user_id')
      .eq('id', id)
      .single();

    if (!existing || existing.user_id !== userId) {
      return jsonResponse({ error: 'Not found' }, { status: 404 });
    }

    const { data, error } = await supabase
      .from('subscriptions')
      .update(body)
      .eq('id', id)
      .select()
      .single();

    if (error) return jsonResponse({ error: 'Failed to update subscription' }, { status: 500 });
    return jsonResponse(data);
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleDeleteSubscription(req: Request, id: string): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: existing } = await supabase
    .from('subscriptions')
    .select('user_id')
    .eq('id', id)
    .single();

  if (!existing || existing.user_id !== userId) {
    return jsonResponse({ error: 'Not found' }, { status: 404 });
  }

  const { error } = await supabase
    .from('subscriptions')
    .delete()
    .eq('id', id);

  if (error) return jsonResponse({ error: 'Failed to delete subscription' }, { status: 500 });
  return jsonResponse({ success: true });
}

async function handleGetCalendarEvents(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const url = new URL(req.url);
  const month = url.searchParams.get('month');
  const year = url.searchParams.get('year');

  const { data: subs } = await supabase
    .from('subscriptions')
    .select('*')
    .eq('user_id', userId);

  if (!subs) return jsonResponse({ error: 'Failed to fetch subscriptions' }, { status: 500 });

  const events = (subs as any[])
    .filter(s => s.renewal_date)
    .map(s => ({
      id: s.id,
      title: s.name,
      date: s.renewal_date,
      cost: s.cost_per_month,
    }));

  return jsonResponse(events);
}

async function handleGetCostPerUse(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const url = new URL(req.url);
  const id = url.searchParams.get('id');

  if (!id) return jsonResponse({ error: 'Subscription ID is required' }, { status: 400 });

  const { data: sub } = await supabase
    .from('subscriptions')
    .select('*')
    .eq('id', id)
    .eq('user_id', userId)
    .single();

  if (!sub) return jsonResponse({ error: 'Not found' }, { status: 404 });

  const { data: usage } = await supabase
    .from('subscription_usage')
    .select('*')
    .eq('subscription_id', id);

  const totalUses = (usage || []).length;
  const costPerUse = totalUses > 0 ? (sub.cost_per_month || 0) / totalUses : 0;

  return jsonResponse({ costPerUse, totalUses, monthlyCost: sub.cost_per_month });
}

async function handleGetVapidPublicKey(req: Request): Promise<Response> {
  return jsonResponse({ vapidPublicKey: VAPID_PUBLIC_KEY });
}

async function handleContactForm(req: Request): Promise<Response> {
  try {
    const body = await req.json() as any;
    const { email, name, message } = body;

    if (!email || !name || !message) {
      return jsonResponse({ error: 'Missing required fields' }, { status: 400 });
    }

    const response = await fetch('https://api.resend.com/emails', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${RESEND_API_KEY}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from: 'noreply@subveris.com',
        to: 'help@subveris.com',
        subject: `New contact form submission from ${name}`,
        html: `<p><strong>From:</strong> ${name} (${email})</p><p><strong>Message:</strong></p><p>${message.replace(/\n/g, '<br>')}</p>`,
      }),
    });

    if (!response.ok) {
      return jsonResponse({ error: 'Failed to send email' }, { status: 500 });
    }

    return jsonResponse({ success: true });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleChangeEmail(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  try {
    const body = await req.json() as any;
    const { newEmail } = body;

    if (!newEmail) return jsonResponse({ error: 'New email is required' }, { status: 400 });

    const { error } = await supabase.auth.admin.updateUserById(userId, {
      email: newEmail,
    });

    if (error) return jsonResponse({ error: error.message }, { status: 500 });
    return jsonResponse({ success: true });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleChangePassword(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  try {
    const body = await req.json() as any;
    const { newPassword } = body;

    if (!newPassword) return jsonResponse({ error: 'New password is required' }, { status: 400 });

    const { error } = await supabase.auth.admin.updateUserById(userId, {
      password: newPassword,
    });

    if (error) return jsonResponse({ error: error.message }, { status: 500 });
    return jsonResponse({ success: true });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleExportData(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: user } = await supabase.auth.admin.getUserById(userId);
  const { data: subs } = await supabase
    .from('subscriptions')
    .select('*')
    .eq('user_id', userId);

  const exportData = {
    user: {
      id: user?.id,
      email: user?.email,
      createdAt: user?.created_at,
    },
    subscriptions: subs || [],
    exportDate: new Date().toISOString(),
  };

  return jsonResponse(exportData);
}

async function handleDeleteAccount(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  try {
    await supabase.from('subscriptions').delete().eq('user_id', userId);
    await supabase.auth.admin.deleteUser(userId);
    return jsonResponse({ success: true });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleGetBehavioralInsights(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: subs } = await supabase
    .from('subscriptions')
    .select('*')
    .eq('user_id', userId);

  if (!subs) return jsonResponse({ error: 'Failed to fetch subscriptions' }, { status: 500 });

  const activeSubs = (subs as any[]).filter(s => s.status === 'active');
  const totalCost = activeSubs.reduce((sum, s) => sum + (s.cost_per_month || 0), 0);
  const categories = activeSubs.reduce((acc, s) => {
    const cat = s.category || 'other';
    acc[cat] = (acc[cat] || 0) + (s.cost_per_month || 0);
    return acc;
  }, {} as Record<string, number>);

  const topCategory = Object.entries(categories).sort(([,a], [,b]) => b - a)[0]?.[0] || 'none';

  return jsonResponse({
    totalActiveSubscriptions: activeSubs.length,
    totalMonthlyCost: totalCost,
    topSpendingCategory: topCategory,
    categoryBreakdown: categories,
    averageCostPerSubscription: activeSubs.length > 0 ? totalCost / activeSubs.length : 0,
  });
}

async function handleGetMonthlySpending(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const url = new URL(req.url);
  const year = Number(url.searchParams.get('year') || new Date().getFullYear());
  const month = Number(url.searchParams.get('month') || (new Date().getMonth() + 1));

  const startDate = new Date(year, month - 1, 1);
  const endDate = new Date(year, month, 1);

  const { data: subs } = await supabase
    .from('subscriptions')
    .select('*')
    .eq('user_id', userId)
    .eq('status', 'active');

  if (!subs) return jsonResponse({ error: 'Failed to fetch subscriptions' }, { status: 500 });

  const monthlyData = (subs as any[]).map(s => ({
    id: s.id,
    name: s.name,
    cost: s.cost_per_month || 0,
    category: s.category || 'other',
  }));

  const totalSpending = monthlyData.reduce((sum, s) => sum + s.cost, 0);

  return jsonResponse({
    year,
    month,
    totalSpending,
    subscriptions: monthlyData,
  });
}

async function handleGetSpendingByCategory(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: subs } = await supabase
    .from('subscriptions')
    .select('*')
    .eq('user_id', userId)
    .eq('status', 'active');

  if (!subs) return jsonResponse({ error: 'Failed to fetch subscriptions' }, { status: 500 });

  const categories = (subs as any[]).reduce((acc, s) => {
    const cat = s.category || 'other';
    if (!acc[cat]) acc[cat] = { totalCost: 0, count: 0, subscriptions: [] };
    acc[cat].totalCost += s.cost_per_month || 0;
    acc[cat].count += 1;
    acc[cat].subscriptions.push({
      id: s.id,
      name: s.name,
      cost: s.cost_per_month || 0,
    });
    return acc;
  }, {} as Record<string, { totalCost: number; count: number; subscriptions: any[] }>);

  return jsonResponse(categories);
}

async function handleGetRecommendations(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: subs } = await supabase
    .from('subscriptions')
    .select('*')
    .eq('user_id', userId)
    .eq('status', 'active');

  if (!subs) return jsonResponse({ error: 'Failed to fetch subscriptions' }, { status: 500 });

  const recommendations = [];
  const activeSubs = subs as any[];

  // Check for unused subscriptions (no usage data)
  for (const sub of activeSubs) {
    const { data: usage } = await supabase
      .from('subscription_usage')
      .select('id')
      .eq('subscription_id', sub.id)
      .limit(1);

    if (!usage || usage.length === 0) {
      recommendations.push({
        type: 'unused',
        subscriptionId: sub.id,
        subscriptionName: sub.name,
        message: `You haven't used ${sub.name} recently. Consider canceling if you don't need it.`,
        savings: sub.cost_per_month || 0,
      });
    }
  }

  // Check for high-cost subscriptions
  const avgCost = activeSubs.length > 0
    ? activeSubs.reduce((sum, s) => sum + (s.cost_per_month || 0), 0) / activeSubs.length
    : 0;

  for (const sub of activeSubs) {
    if ((sub.cost_per_month || 0) > avgCost * 1.5) {
      recommendations.push({
        type: 'high_cost',
        subscriptionId: sub.id,
        subscriptionName: sub.name,
        message: `${sub.name} costs significantly more than your average subscription.`,
        savings: 0, // Not suggesting cancellation
      });
    }
  }

  return jsonResponse(recommendations);
}

async function handleGetFamilyGroups(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: groups } = await supabase
    .from('family_groups')
    .select('*')
    .eq('owner_id', userId);

  return jsonResponse(groups || []);
}

async function handleCreateFamilyGroup(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  try {
    const body = await req.json() as any;
    const { name } = body;

    if (!name) return jsonResponse({ error: 'Name is required' }, { status: 400 });

    const { data, error } = await supabase
      .from('family_groups')
      .insert({
        owner_id: userId,
        name,
        created_at: new Date().toISOString(),
      })
      .select()
      .single();

    if (error) return jsonResponse({ error: 'Failed to create family group' }, { status: 500 });
    return jsonResponse(data, { status: 201 });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleGetFamilyMembership(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: membership } = await supabase
    .from('family_group_members')
    .select(`
      *,
      family_groups (*)
    `)
    .eq('user_id', userId)
    .single();

  if (!membership) return jsonResponse(null);

  return jsonResponse(membership);
}

async function handleGetAnalysisCostPerUse(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  const { data: subs } = await supabase
    .from('subscriptions')
    .select('*')
    .eq('user_id', userId)
    .eq('status', 'active');

  if (!subs) return jsonResponse({ error: 'Failed to fetch subscriptions' }, { status: 500 });

  const analysis = await Promise.all((subs as any[]).map(async (sub) => {
    const { data: usage } = await supabase
      .from('subscription_usage')
      .select('*')
      .eq('subscription_id', sub.id);

    const totalUses = (usage || []).length;
    const costPerUse = totalUses > 0 ? (sub.cost_per_month || 0) / totalUses : 0;

    return {
      subscriptionId: sub.id,
      subscriptionName: sub.name,
      monthlyCost: sub.cost_per_month || 0,
      totalUses,
      costPerUse,
      lastUsed: usage && usage.length > 0 ? Math.max(...usage.map((u: any) => new Date(u.created_at).getTime())) : null,
    };
  }));

  return jsonResponse(analysis);
}

async function handleNotificationSubscribe(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  try {
    const body = await req.json() as any;
    const { subscription } = body;

    if (!subscription) return jsonResponse({ error: 'Subscription is required' }, { status: 400 });

    // Store the subscription in the database
    const { error } = await supabase
      .from('push_subscriptions')
      .upsert({
        user_id: userId,
        subscription: subscription,
        updated_at: new Date().toISOString(),
      }, { onConflict: 'user_id' });

    if (error) return jsonResponse({ error: 'Failed to save subscription' }, { status: 500 });

    return jsonResponse({ success: true });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

async function handleNotificationSubscribe(req: Request): Promise<Response> {
  const userId = await getUserIdFromRequest(req);
  if (!userId) return jsonResponse({ error: 'Unauthorized' }, { status: 401 });

  try {
    const body = await req.json() as any;
    const { subscription } = body;

    if (!subscription) return jsonResponse({ error: 'Subscription data is required' }, { status: 400 });

    const { error } = await supabase
      .from('push_subscriptions')
      .insert({
        user_id: userId,
        subscription_data: subscription,
        created_at: new Date().toISOString(),
      });

    if (error) return jsonResponse({ error: 'Failed to save subscription' }, { status: 500 });
    return jsonResponse({ success: true });
  } catch (error) {
    return jsonResponse({ error: (error as Error).message }, { status: 500 });
  }
}

Deno.serve(async (req: Request) => {
  // Handle CORS preflight
  if (req.method === 'OPTIONS') {
    return new Response('', {
      headers: {
        'Access-Control-Allow-Origin': '*',
        'Access-Control-Allow-Methods': 'GET,POST,PUT,PATCH,DELETE,OPTIONS',
        'Access-Control-Allow-Headers': 'Authorization,Content-Type',
      },
    });
  }

  const url = new URL(req.url);
  const pathname = url.pathname.replace(/^\/functions\/(v1\/)?api/, '') || '/';

  // Route handlers
  if (pathname === '/metrics' && req.method === 'GET') {
    return await handleGetMetrics(req);
  }

  if (pathname === '/stripe/create-checkout-session' && req.method === 'POST') {
    return await handleCreateCheckoutSession(req);
  }

  if (pathname === '/user/premium-status' && req.method === 'GET') {
    return await handleGetPremiumStatus(req);
  }

  if (pathname === '/user/currency' && req.method === 'PATCH') {
    return await handlePatchUserCurrency(req);
  }

  if (pathname === '/account/notification-preferences' && req.method === 'GET') {
    return await handleGetNotificationPreferences(req);
  }

  if (pathname === '/account/notification-preferences' && req.method === 'PATCH') {
    return await handlePatchNotificationPreferences(req);
  }

  if (pathname === '/stripe/complete-checkout-session' && req.method === 'POST') {
    return await handleCompleteCheckoutSession(req);
  }

  if (pathname === '/stripe/subscription-status' && req.method === 'GET') {
    return await handleGetStripeSubscriptionStatus(req);
  }

  if (pathname === '/stripe/cancel-subscription' && req.method === 'POST') {
    return await handleCancelSubscription(req);
  }

  if (pathname === '/stripe/reactivate-subscription' && req.method === 'POST') {
    return await handleReactivateSubscription(req);
  }

  if (pathname === '/stripe/webhook' && req.method === 'POST') {
    return await handleStripeWebhook(req);
  }

  if (pathname === '/subscriptions' && req.method === 'GET') {
    return await handleGetListSubscriptions(req);
  }

  if (pathname === '/subscriptions' && req.method === 'POST') {
    return await handleCreateSubscription(req);
  }

  if (pathname.match(/^\/subscriptions\/[^/]+$/) && req.method === 'PUT') {
    const id = pathname.split('/').pop();
    return await handleUpdateSubscription(req, id!);
  }

  if (pathname.match(/^\/subscriptions\/[^/]+$/) && req.method === 'DELETE') {
    const id = pathname.split('/').pop();
    return await handleDeleteSubscription(req, id!);
  }

  if (pathname === '/calendar-events' && req.method === 'GET') {
    return await handleGetCalendarEvents(req);
  }

  if (pathname === '/cost-per-use' && req.method === 'GET') {
    return await handleGetCostPerUse(req);
  }

  if (pathname === '/vapid-public-key' && req.method === 'GET') {
    return await handleGetVapidPublicKey(req);
  }

  if (pathname === '/contact' && req.method === 'POST') {
    return await handleContactForm(req);
  }

  if (pathname === '/account/email' && req.method === 'PATCH') {
    return await handleChangeEmail(req);
  }

  if (pathname === '/account/password' && req.method === 'PATCH') {
    return await handleChangePassword(req);
  }

  if (pathname === '/account/export' && req.method === 'GET') {
    return await handleExportData(req);
  }

  if (pathname === '/account' && req.method === 'DELETE') {
    return await handleDeleteAccount(req);
  }

  if (pathname === '/insights/behavioral' && req.method === 'GET') {
    return await handleGetBehavioralInsights(req);
  }

  if (pathname === '/spending/monthly' && req.method === 'GET') {
    return await handleGetMonthlySpending(req);
  }

  if (pathname === '/spending/category' && req.method === 'GET') {
    return await handleGetSpendingByCategory(req);
  }

  if (pathname === '/recommendations' && req.method === 'GET') {
    return await handleGetRecommendations(req);
  }

  if (pathname === '/family-groups' && req.method === 'GET') {
    return await handleGetFamilyGroups(req);
  }

  if (pathname === '/family-groups' && req.method === 'POST') {
    return await handleCreateFamilyGroup(req);
  }

  if (pathname === '/family-groups/me/membership' && req.method === 'GET') {
    return await handleGetFamilyMembership(req);
  }

  if (pathname === '/analysis/cost-per-use' && req.method === 'GET') {
    return await handleGetAnalysisCostPerUse(req);
  }

  if (pathname === '/notifications/subscribe' && req.method === 'POST') {
    return await handleNotificationSubscribe(req);
  }

  // 404
  return new Response(JSON.stringify({ error: 'Not found' }), {
    status: 404,
    headers: {
      'Content-Type': 'application/json',
      'Access-Control-Allow-Origin': '*',
    },
  });
});
